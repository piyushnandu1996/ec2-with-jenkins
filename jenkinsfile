pipeline{
  agent any
    
    parameters{
        booleanParam(name: 'autoApprove', defaultValue: false, description: 'Automatically run apply after generating plan')
        choice(name: 'action', choices: ["apply", "destroy"], description: 'select action to perform')

    }

    environment {
        AWS_ACCESS_KEY_ID = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
    }
    stages{
        stage("git clone"){
            steps{
                git branch:"main", url:"https://github.com/piyushnandu1996/ec2-with-jenkins.git"

            }
        }

        stage('initialise terraform'){
            steps{
                sh 'terraform init'
            }
        }

        stage('validatting'){
            steps{
                sh 'terraform validate'
            }
        }

        stage('formatting'){
            steps{
                sh 'terraform fmt'
            }
        }

        stage('planning before deploying'){
            steps{
                sh 'terraform plan -out=tfout'
            }
        }

        stage('apply/destroy'){
            steps{
                script {
                    if (params.action == "apply") {
                        if (!params.autoApprove) {
                            input message: "Do you want to apply the plan?"
                            sh 'terraform apply tfout'
                        } else {
                            sh 'terraform apply tfout'
                        }
                    } else if (params.action == "destroy") {
                        input message: "Do you want to destroy the plan?"
                        sh 'terraform destroy'
                    }

                }

            }
        }




    }    

}
